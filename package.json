{
  "name": "demitech-bot",
  "version": "1.0.0",
  "description": "Demitech Lead Acquisition Bot",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
