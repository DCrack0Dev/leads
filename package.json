    "build": "npm run build --prefix client",
    "install-all": "npm install && npm install --prefix server && npm install --prefix client"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "puppeteer": "^21.5.2",
    "sib-api-v3-sdk": "^8.5.0",
    "slugify": "^1.6.6",
    "sqlite3": "^5.1.6",
    "twilio": "^5.13.1"
  }
}
